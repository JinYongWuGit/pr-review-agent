# Copy to .env and fill in (do not commit .env)
PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT
PR_RVW_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
PR_RVW_AGENT_NAME=pr-review-agent

# Optional: override default instructions in scripts/create_agent.py
# AGENT_INSTRUCTIONS=...

# TLS: truststore uses the OS cert store (helps corporate SSL inspection). Set 0 for certifi-only.
# USE_OS_TRUST_STORE=1

# Optional: model also emits review_threads.json for inline PR threads (see scripts/post_pr_review.py).
# PR_REVIEW_INLINE_JSON=1
# Snap thread anchors to real '+' lines from the diff using @tokens (default on; set 0 to disable).
# PR_REVIEW_SNAP_THREAD_LINES=1
